{
  "name": "@fyrendev/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "dev:test": "bun run --env-file .env.test --watch src/index.ts",
    "worker": "bun run src/worker.ts",
    "dev:worker": "bun run --watch src/worker.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "start": "bun run dist/index.js",
    "lint": "tsc --noEmit",
    "test": "bun test --env-file .env.test",
    "test:watch": "bun test --env-file .env.test --watch"
  },
  "dependencies": {
    "@aws-sdk/client-ses": "^3.958.0",
    "@fyrendev/db": "workspace:*",
    "@fyrendev/shared": "workspace:*",
    "@hono/zod-validator": "^0.7.6",
    "bcryptjs": "^3.0.3",
    "better-auth": "^1.4.9",
    "bullmq": "^5.34.3",
    "date-fns": "^4.1.0",
    "hono": "^4.6.14",
    "ioredis": "^5.4.2",
    "nodemailer": "^7.0.12",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/bun": "^1.1.14",
    "@types/nodemailer": "^7.0.4",
    "typescript": "^5.7.2"
  }
}
