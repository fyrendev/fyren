{
  "name": "@fyrendev/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "dev:test": "bun run --env-file .env.test --watch src/index.ts",
    "worker": "bun run src/worker.ts",
    "dev:worker": "bun run --watch src/worker.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "start": "bun run dist/index.js",
    "lint": "NODE_OPTIONS='--max-old-space-size=8192' tsc --noEmit",
    "test": "bun test",
    "test:watch": "bun test --watch"
  },
  "dependencies": {
    "@aws-sdk/client-ses": "^3.1019.0",
    "@fyrendev/db": "workspace:*",
    "@fyrendev/shared": "workspace:*",
    "@hono/mcp": "^0.2.4",
    "@hono/zod-validator": "^0.7.6",
    "@modelcontextprotocol/sdk": "^1.28.0",
    "bcryptjs": "^3.0.3",
    "better-auth": "^1.5.6",
    "bullmq": "^5.71.1",
    "date-fns": "^4.1.0",
    "hono": "^4.12.9",
    "ioredis": "^5.10.1",
    "nats": "^2.29.3",
    "nodemailer": "^8.0.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/bun": "^1.3.11",
    "@types/nodemailer": "^7.0.11",
    "typescript": "^6.0.2"
  }
}
