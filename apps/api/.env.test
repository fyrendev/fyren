# Test Environment Variables
# Used when running integration/E2E tests

PORT=3001
NODE_ENV=test

# Test database - separate from development database
DATABASE_URL=postgres://fyren:fyren@localhost:5432/fyren_test

# Cache (Redis) - uses same instance but different database number
REDIS_URL=redis://localhost:6379/1

# Auth (BetterAuth)
BETTER_AUTH_SECRET=test-secret-key-for-testing-only-32chars
BETTER_AUTH_URL=http://localhost:3001
APP_URL=http://localhost:3000

# Email provider - use console for tests
EMAIL_PROVIDER=console
EMAIL_FROM=test@fyren.dev
