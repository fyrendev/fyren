# Fyren Production Environment Variables
# Copy to .env.prod and fill in values

# ===================================
# Domain Configuration (Required)
# ===================================
APP_URL=https://status.example.com
APP_DOMAIN=status.example.com
ACME_EMAIL=admin@example.com

# ===================================
# Database (Required)
# ===================================
POSTGRES_DB=fyren
POSTGRES_USER=fyren
POSTGRES_PASSWORD=CHANGE_THIS_SECURE_PASSWORD

# ===================================
# Redis (Required)
# ===================================
REDIS_PASSWORD=CHANGE_THIS_REDIS_PASSWORD

# ===================================
# Authentication (Required)
# ===================================
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=CHANGE_THIS_32_CHAR_MIN_SECRET

# ===================================
# Email Configuration (Optional)
# ===================================
# Provider: console (dev), ses, sendgrid, smtp
EMAIL_PROVIDER=console
EMAIL_FROM=noreply@example.com

# AWS SES Configuration
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# SendGrid Configuration
# SENDGRID_API_KEY=

# SMTP Configuration
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
