# Fyren Environment Variables

# Server
PORT=3001
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL=postgres://fyren:fyren@localhost:5432/fyren

# Cache (Redis)
REDIS_URL=redis://localhost:6379

# Auth (BetterAuth)
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=your-secret-key-min-32-chars-here
BETTER_AUTH_URL=http://localhost:3001
APP_URL=http://localhost:3001

# Email provider: 'ses' | 'sendgrid' | 'smtp' | 'console'
EMAIL_PROVIDER=console
EMAIL_FROM=noreply@fyren.dev

# AWS SES (if EMAIL_PROVIDER=ses)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# SendGrid (if EMAIL_PROVIDER=sendgrid)
SENDGRID_API_KEY=

# SMTP (if EMAIL_PROVIDER=smtp)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
