# Fyren Environment Variables

# Server
PORT=3001
NODE_ENV=development

# Database (PostgreSQL)
# Development database
DATABASE_URL=postgres://fyren:fyren@localhost:5432/fyren
# Test database (used by E2E and integration tests)
# Created automatically by docker/init-db.sh on first container start
# TEST_DATABASE_URL=postgres://fyren:fyren@localhost:5432/fyren_test

# Cache (Redis)
# Development uses db 0, tests use db 1
REDIS_URL=redis://localhost:6379

# Auth (BetterAuth)
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=your-secret-key-min-32-chars-here
BETTER_AUTH_URL=http://localhost:3001
APP_URL=http://localhost:3000

# Encryption key for sensitive data (email provider credentials)
# Generate with: openssl rand -hex 32
# Required if you want to configure email providers via the settings UI
ENCRYPTION_KEY=
