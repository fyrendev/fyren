# Fyren Environment Variables

# Server
PORT=3001
NODE_ENV=development

# Database (PostgreSQL)
# Development database
DATABASE_URL=postgres://fyren:fyren@localhost:5432/fyren
# Test database (used by E2E and integration tests)
# Created automatically by docker/init-db.sh on first container start
# TEST_DATABASE_URL=postgres://fyren:fyren@localhost:5432/fyren_test

# Cache (Redis)
# Development uses db 0, tests use db 1
REDIS_URL=redis://localhost:6379

# Auth (BetterAuth)
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=your-secret-key-min-32-chars-here
BETTER_AUTH_URL=http://localhost:3001
APP_URL=http://localhost:3000
# Cookie domain for cross-subdomain auth (optional)
# Set this when API and web are on different subdomains (e.g., api.example.com and app.example.com)
# Must start with a dot (e.g., ".example.com") to share cookies across subdomains
# COOKIE_DOMAIN=.example.com

# Encryption key for sensitive data (email provider credentials)
# Generate with: openssl rand -hex 32
# Required if you want to configure email providers via the settings UI
ENCRYPTION_KEY=

# Security: One-time setup token for initial organization creation
# Prevents unauthenticated instance takeover before first user signs up
# Generate with: openssl rand -hex 32
# SETUP_TOKEN=

# Security: Comma-separated list of trusted proxy IPs
# Only trust X-Forwarded-For when request comes from these IPs
# Required for accurate rate limiting behind a reverse proxy
# TRUSTED_PROXIES=10.0.0.1,172.16.0.0/12

# Security: Allowed origins for widget embedding (CSP frame-ancestors)
# Space-separated list of origins. Default: "*" (allow all)
# WIDGET_ALLOWED_ORIGINS=https://example.com https://other.com

# Logging Configuration
# Provider: "console" (default), "loki", or "otlp"
LOG_PROVIDER=console
# Level: "debug", "info" (default), "warn", or "error"
LOG_LEVEL=info
# Service name for log tagging
LOG_SERVICE_NAME=fyren-api

# Loki Configuration (when LOG_PROVIDER=loki)
# LOKI_URL=http://localhost:3100
# LOKI_USERNAME=
# LOKI_PASSWORD=
# LOKI_TENANT_ID=

# OTLP Configuration (when LOG_PROVIDER=otlp)
# OTLP_ENDPOINT=http://localhost:4318
# OTLP_HEADERS={"Authorization":"Bearer token"}
