{
  "name": "fyren",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "dev:all": "turbo run dev dev:worker",
    "build": "turbo run build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "turbo run lint",
    "db:generate": "turbo run db:generate --filter=@fyrendev/db",
    "db:migrate": "turbo run db:migrate --filter=@fyrendev/db",
    "db:push": "turbo run db:push --filter=@fyrendev/db",
    "db:push:test": "DATABASE_URL=postgres://fyren:fyren@localhost:5432/fyren_test turbo run db:push --filter=@fyrendev/db",
    "db:studio": "turbo run db:studio --filter=@fyrendev/db",
    "db:seed": "turbo run db:seed --filter=@fyrendev/db",
    "test:e2e": "bun run db:push:test && cd apps/web && bun run test:e2e",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.7.4",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.51.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,scss,yaml,yml}": [
      "prettier --write"
    ]
  },
  "packageManager": "bun@1.1.38",
  "overrides": {
    "zod": "4.3.6"
  }
}
